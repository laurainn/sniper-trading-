# ============================================================================
# RPC CONNECTION
# Public RPCs (api.mainnet-beta.solana.com) are rate-limited and too slow for
# sniping - by the time you see a new pool, the good fills are gone. Use a
# low-latency provider: Helius, QuickNode, Triton, or Chainstack all offer
# paid plans built for this. Put your HTTP and WebSocket URLs below.
# ============================================================================
RPC_HTTP_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY_HERE
RPC_WS_URL=wss://mainnet.helius-rpc.com/?api-key=YOUR_KEY_HERE

# ============================================================================
# WALLET
# Run `npm run generate-wallet` to create a fresh burner wallet - never point
# this bot at a wallet that holds funds you care about. Paste the base58
# secret key it prints below. Keep this file out of version control.
# ============================================================================
PRIVATE_KEY=

# ============================================================================
# JUPITER API
# Free tier (lite-api.jup.ag) works with no key but has lower rate limits.
# Get a free/paid key at https://portal.jup.ag for higher throughput.
# ============================================================================
JUPITER_API_KEY=

# ============================================================================
# SAFETY SWITCH
# DRY_RUN=true simulates everything (detection, safety checks, "fills") using
# real market data but sends no transactions and risks no funds. Leave this
# true until you've watched it run for a while and trust what it's doing.
# ============================================================================
DRY_RUN=true

# ============================================================================
# TRADING PARAMETERS
# ============================================================================
# SOL spent per snipe
BUY_AMOUNT_SOL=0.05
# Max acceptable slippage on entry, in basis points (500 = 5%)
MAX_SLIPPAGE_BPS=500
# Max acceptable price impact on the BUY quote before we walk away (percent)
MAX_PRICE_IMPACT_PCT=15
# Take profit / stop loss, as a percent move from entry
TAKE_PROFIT_PCT=50
STOP_LOSS_PCT=25
# How often to re-check open positions for TP/SL, in milliseconds
POSITION_CHECK_INTERVAL_MS=5000
# Max number of tokens held at once
MAX_CONCURRENT_POSITIONS=3
# Circuit breaker: stop opening new trades once today's realized losses hit
# this many SOL (resets at UTC midnight)
DAILY_LOSS_LIMIT_SOL=0.5
