# ============================================================================
# RPC CONNECTION
# Using public endpoints for testing. For production, use a paid endpoint.
# ============================================================================
RPC_HTTP_URL=https://api.mainnet-beta.solana.com
RPC_WS_URL=wss://api.mainnet-beta.solana.com

# ============================================================================
# WALLET
# IMPORTANT: Generate a fresh burner wallet with: npm run generate-wallet
# Do NOT use this placeholder - replace with your own private key!
# ============================================================================
PRIVATE_KEY=YOUR_BASE58_PRIVATE_KEY_HERE

# ============================================================================
# JUPITER API
# Optional: Get a free key at https://portal.jup.ag for better rate limits
# ============================================================================
JUPITER_API_KEY=

# ============================================================================
# SAFETY SWITCH - SET TO TRUE FOR DRY RUN (TEST MODE)
# DRY_RUN=true means no real transactions are sent
# Only set to false once you understand the risks and have tested thoroughly
# ============================================================================
DRY_RUN=true

# ============================================================================
# TRADING PARAMETERS - Conservative defaults for testing
# ============================================================================
BUY_AMOUNT_SOL=0.05
MAX_SLIPPAGE_BPS=500
MAX_PRICE_IMPACT_PCT=15
TAKE_PROFIT_PCT=50
STOP_LOSS_PCT=25
POSITION_CHECK_INTERVAL_MS=5000
MAX_CONCURRENT_POSITIONS=3
DAILY_LOSS_LIMIT_SOL=0.5
